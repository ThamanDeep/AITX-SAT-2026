# Copy to .env and fill in. Never commit .env.

# ─── NVIDIA Endpoints (build.nvidia.com) ─────────────────────
NVIDIA_INFERENCE_API_KEY=nvapi-...

# ─── Model / sandbox ─────────────────────────────────────────
NEMOCLAW_MODEL=nvidia/nemotron-3-super-120b-a12b
NEMOCLAW_SANDBOX_NAME=openclaw
NEMOCLAW_POLICY_TIER=balanced

# ─── Web search ──────────────────────────────────────────────
NEMOCLAW_WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=tvly-...

# ─── Discord ─────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
# per-agent bot identities (optional; leave empty for single-bot mode)
DISCORD_BOT_TOKEN_SCOUT=
DISCORD_BOT_TOKEN_INSPECTOR=
DISCORD_BOT_TOKEN_CONCIERGE=
DISCORD_SERVER_ID=1527850934535717055
DISCORD_REQUIRE_MENTION=1

# ─── Ports (change when running several stacks on one host) ──
NEMOCLAW_GATEWAY_PORT=8080
NEMOCLAW_DASHBOARD_PORT=18789
NEMOCLAW_BIN_PATH=/tmp/nemoclaw-bin

# ─── Retail data APIs (internal agents; optional until keys exist) ──
EBAY_APP_ID=
EBAY_CERT_ID=
BESTBUY_API_KEY=
AMAZON_PAAPI_ACCESS_KEY=
AMAZON_PAAPI_SECRET=
AMAZON_PARTNER_TAG=
